# Production env for Docker Compose (keep separate from local .env).
#   cp .env.production.example .env.production
#   # Set a strong POSTGRES_PASSWORD before first boot
#   docker compose --env-file .env.production up -d --build
#
# Cloudflare Tunnel should target: http://localhost:3000
# Postgres is internal-only (not published on the host).

NODE_ENV=production
PORT=3000

# Postgres (compose service name = postgres)
POSTGRES_USER=recruiter
# REQUIRED. Applied only when volume postgres-data is first created.
# Replace before any public deploy. To rotate later:
#   docker compose --env-file .env.production down -v && docker compose --env-file .env.production up -d --build
POSTGRES_PASSWORD=CHANGE_ME_BEFORE_PRODUCTION
POSTGRES_DB=recruiter_copilot

# Used by api container (override only if not using compose defaults)
# DATABASE_URL is set in docker-compose.yml from POSTGRES_* vars.
PERSISTENCE_DRIVER=prisma

DEFAULT_WORKSPACE_ID=ws_default
FEATURE_FLAGS_FILE=feature-flags/sprint-1.yaml

LOG_FORMAT=json
LOG_LEVEL=info
APP_VERSION=0.1.0

RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=120
MAX_FILE_SIZE_BYTES=10485760

# Keep false on public VPS unless tunnelled
OPERATIONS_DASHBOARD_ENABLED=false
