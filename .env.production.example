# Production env for Docker Compose (keep separate from local .env).
#   cp .env.production.example .env.production
#   # Set a strong POSTGRES_PASSWORD before first boot
#   docker compose --env-file .env.production up -d --build
#
# NEVER commit .env.production.

NODE_ENV=production
PORT=3000

# Postgres (compose service name = postgres)
POSTGRES_USER=recruiter
POSTGRES_PASSWORD=CHANGE_ME_BEFORE_PRODUCTION
POSTGRES_DB=recruiter_copilot

# API uses Prisma → PostgreSQL (DATABASE_URL injected by docker-compose.yml)
PERSISTENCE_DRIVER=prisma

# Optional: run prisma db seed on container start (default false)
RUN_DB_SEED=false

DEFAULT_WORKSPACE_ID=ws_default
FEATURE_FLAGS_FILE=feature-flags/sprint-1.yaml

LOG_FORMAT=json
LOG_LEVEL=info
APP_VERSION=0.1.0

RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=120
MAX_FILE_SIZE_BYTES=10485760
OPERATIONS_DASHBOARD_ENABLED=false

# Reserved for future token auth (not required for MVP x-actor-id)
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET

# Nginx / Let's Encrypt (optional — compose profiles proxy + ssl)
# DOMAIN=app.example.com
# CERTBOT_EMAIL=ops@example.com
