# Local development
PORT=3000
NODE_ENV=development

# Persistence
# - memory (default for local unit tests / pnpm dev)
# - prisma + PostgreSQL for production / integration tests
PERSISTENCE_DRIVER=memory

# PostgreSQL (required when PERSISTENCE_DRIVER=prisma)
# DATABASE_URL=postgresql://recruiter:recruiter@localhost:5432/recruiter_copilot?schema=public
# Integration tests: TEST_DATABASE_URL=postgresql://recruiter:recruiter@localhost:5432/recruiter_copilot_test?schema=public

FEATURE_FLAGS_FILE=feature-flags/sprint-1.yaml
STORAGE_PATH=./data/resumes
TELEMETRY_PATH=./data/telemetry/events.jsonl
DEFAULT_WORKSPACE_ID=ws_default

# Request / upload limits
MAX_FILE_SIZE_BYTES=10485760
MAX_JSON_BODY_BYTES=1048576
MAX_REQUEST_BODY_BYTES=11010048

# Rate limiting (default ON in production, OFF in development)
# RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Operations Dashboard — enabled in development by default
# OPERATIONS_DASHBOARD_ENABLED=true

# Optional — Mock providers used when unset (ADR-016)
GEMINI_API_KEY=

# Logging
# LOG_FORMAT=json
# LOG_LEVEL=info
# APP_VERSION=0.1.0
# BUILD_TIMESTAMP=

# Optional app secret (reserved for future auth tokens; not used by MVP actor header)
# JWT_SECRET=change-me
