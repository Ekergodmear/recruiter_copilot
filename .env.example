# Local development
PORT=3000
NODE_ENV=development

# TECH-001 persistence
# Development/unit tests default to in-memory (PERSISTENCE_DRIVER=memory).
# Production / Alpha smoke: PERSISTENCE_DRIVER=prisma
PERSISTENCE_DRIVER=memory
# SQLite (default for Alpha local). Override with Postgres URL when ready.
DATABASE_URL="file:./data/recruiter_copilot.db"
# DATABASE_URL=postgresql://recruiter:recruiter@localhost:5432/recruiter_copilot

FEATURE_FLAGS_FILE=feature-flags/sprint-1.yaml
STORAGE_PATH=./data/resumes
TELEMETRY_PATH=./data/telemetry/events.jsonl
DEFAULT_WORKSPACE_ID=ws_default

# TECH-005 — request / upload limits
MAX_FILE_SIZE_BYTES=10485760
MAX_JSON_BODY_BYTES=1048576
MAX_REQUEST_BODY_BYTES=11010048

# TECH-005 — rate limiting (default ON in production, OFF in development)
# RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Operations Dashboard — enabled in development by default
# OPERATIONS_DASHBOARD_ENABLED=true

# Optional — Mock providers used when unset (ADR-016)
GEMINI_API_KEY=

# TECH-004 logging
# LOG_FORMAT=json
# LOG_LEVEL=info
# APP_VERSION=0.1.0
# BUILD_TIMESTAMP=
