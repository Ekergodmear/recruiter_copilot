{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "KC-001 Output — Resume to Skill Knowledge",
  "type": "object",
  "required": ["skills", "contract_id", "trace_id", "extraction_method", "executed_at"],
  "properties": {
    "skills": {
      "type": "array",
      "items": { "$ref": "#/definitions/skillKnowledge" }
    },
    "contract_id": { "const": "KC-001" },
    "trace_id": { "type": "string", "minLength": 1 },
    "extraction_method": { "type": "string", "minLength": 1 },
    "executed_at": { "type": "string", "format": "date-time" }
  },
  "definitions": {
    "skillKnowledge": {
      "type": "object",
      "required": [
        "knowledge_type",
        "entity_type",
        "entity_id",
        "workspace_id",
        "value",
        "confidence",
        "sources",
        "last_updated",
        "version",
        "trace_id",
        "evidence_ref"
      ],
      "properties": {
        "knowledge_id": { "type": "string" },
        "knowledge_type": { "const": "skill" },
        "entity_type": { "const": "candidate" },
        "entity_id": { "type": "string" },
        "workspace_id": { "type": "string" },
        "value": {
          "type": "object",
          "required": ["skill_id", "normalized_name"],
          "properties": {
            "skill": { "type": "string" },
            "skill_id": { "type": "string" },
            "normalized_name": { "type": "string" },
            "category": { "type": "string" },
            "proficiency": {
              "enum": ["expert", "advanced", "intermediate", "beginner", "unknown"]
            },
            "years_of_experience": { "type": "number", "minimum": 0 },
            "last_used": { "type": "string" }
          }
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "sources": {
          "type": "array",
          "items": { "type": "string" },
          "contains": { "const": "Resume" }
        },
        "last_updated": { "type": "string", "format": "date-time" },
        "version": { "type": "integer", "minimum": 1 },
        "trace_id": { "type": "string" },
        "evidence_ref": { "type": "string" }
      }
    }
  }
}
