{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "KC-002 Output — Resume to English Knowledge",
  "type": "object",
  "required": ["english", "contract_id", "trace_id", "extraction_method", "executed_at"],
  "properties": {
    "english": { "$ref": "#/definitions/englishKnowledge" },
    "contract_id": { "const": "KC-002" },
    "trace_id": { "type": "string", "minLength": 1 },
    "extraction_method": { "type": "string", "minLength": 1 },
    "executed_at": { "type": "string", "format": "date-time" }
  },
  "definitions": {
    "englishKnowledge": {
      "type": "object",
      "required": [
        "knowledge_type",
        "entity_type",
        "entity_id",
        "workspace_id",
        "value",
        "confidence",
        "sources",
        "last_updated",
        "version",
        "trace_id",
        "evidence_ref"
      ],
      "properties": {
        "knowledge_id": { "type": "string" },
        "knowledge_type": { "const": "english" },
        "entity_type": { "const": "candidate" },
        "entity_id": { "type": "string" },
        "workspace_id": { "type": "string" },
        "value": {
          "type": "object",
          "required": ["level"],
          "properties": {
            "level": {
              "enum": ["A1", "A2", "B1", "B2", "C1", "C2", "unknown"]
            },
            "level_numeric": { "type": "integer", "minimum": 1, "maximum": 6 },
            "speaking": {
              "enum": ["fluent", "good", "fair", "poor", "unknown"]
            },
            "writing": {
              "enum": ["fluent", "good", "fair", "poor", "unknown"]
            },
            "certifications": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "sources": {
          "type": "array",
          "items": { "type": "string" },
          "contains": { "const": "Resume" }
        },
        "last_updated": { "type": "string", "format": "date-time" },
        "version": { "type": "integer", "minimum": 1 },
        "trace_id": { "type": "string" },
        "evidence_ref": { "type": "string" }
      }
    }
  }
}
