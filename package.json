{
  "name": "recruiter-copilot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/app/server.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "dev:app": "concurrently -n api,web -c blue,green \"pnpm run dev\" \"pnpm run dev:web\"",
    "build:web": "vite build --config web/vite.config.ts",
    "start": "node dist/app/server.js",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "format": "prettier --write \"{src,tests,scripts,sprints}/**/*.{ts,js,json}\" \"*.{md,json}\" \"contracts/**/*.json\" \"fixtures/**/*.json\" \"telemetry/**/*.json\"",
    "format:check": "prettier --check \"{src,tests,scripts,sprints}/**/*.{ts,js,json}\" \"*.{md,json}\" \"contracts/**/*.json\" \"fixtures/**/*.json\" \"telemetry/**/*.json\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:contracts": "tsx scripts/validate-contracts.ts",
    "eval:resume": "tsx scripts/eval-resume.ts",
    "report:weekly": "tsx scripts/generate-weekly-report.ts",
    "verify:data": "tsx scripts/verify-data.ts",
    "security:smoke": "tsx scripts/security-smoke.ts",
    "bench:import": "tsx scripts/benchmark/benchmark-import.ts",
    "bench:review": "tsx scripts/benchmark/benchmark-review.ts",
    "bench:insight": "tsx scripts/benchmark/benchmark-insight.ts",
    "bench:verify-data": "tsx scripts/benchmark/benchmark-verify-data.ts",
    "bench:all": "tsx scripts/benchmark/run-all.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.mjs",
    "ci": "pnpm run db:generate && pnpm run format:check && pnpm run lint && pnpm run build && pnpm run test && pnpm run test:contracts && pnpm run eval:resume && pnpm run verify:data && pnpm run security:smoke"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.3.0",
    "@prisma/client": "5.22.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "fastify": "^5.2.1",
    "js-yaml": "^4.1.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.9.0",
    "pdf-parse": "^1.1.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.10",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "eslint": "^9.21.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "prisma": "5.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "vite": "^8.1.4",
    "vitest": "^3.0.8"
  }
}
