{
  "name": "recruiter-copilot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/app/server.ts",
    "start": "node dist/app/server.js",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "format": "prettier --write \"{src,tests,scripts,sprints}/**/*.{ts,js,json}\" \"*.{md,json}\" \"contracts/**/*.json\" \"fixtures/**/*.json\" \"telemetry/**/*.json\"",
    "format:check": "prettier --check \"{src,tests,scripts,sprints}/**/*.{ts,js,json}\" \"*.{md,json}\" \"contracts/**/*.json\" \"fixtures/**/*.json\" \"telemetry/**/*.json\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:contracts": "tsx scripts/validate-contracts.ts",
    "eval:resume": "tsx scripts/eval-resume.ts",
    "ci": "pnpm run format:check && pnpm run lint && pnpm run build && pnpm run test && pnpm run test:contracts && pnpm run eval:resume"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "fastify": "^5.2.1",
    "@fastify/multipart": "^9.0.3",
    "js-yaml": "^4.1.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.9.0",
    "pdf-parse": "^1.1.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.10",
    "@types/pdf-parse": "^1.1.4",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.21.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "vitest": "^3.0.8"
  }
}
